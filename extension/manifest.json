{
    "manifest_version": 3,
    "name": "MASM - Account Sharing Manager",
    "version": "1.0.0",
    "description": "Multi-Account Sharing Platform - Cookie injection and session management",
    "permissions": [
        "cookies",
        "tabs",
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://*.netflix.com/*",
        "https://*.spotify.com/*",
        "https://*.disneyplus.com/*",
        "https://*.youtube.com/*",
        "https://*.amazon.com/*",
        "https://*.crunchyroll.com/*",
        "http://localhost:5000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "externally_connectable": {
        "matches": [
            "http://localhost:3000/*"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "http://localhost:3000/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}